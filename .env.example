# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

# Add API keys for connecting to LLM providers, data sources, and other integrations here
GOOGLE_API_KEY=xxx
INVOKE_AGENT_API_KEY=xxx # Optional: defaults to GOOGLE_API_KEY
MUTATION_ENGINE_API_KEY=xxx # Optional: defaults to GOOGLE_API_KEY
BEHAVIORAL_ENGINE_API_KEY=xxx # Optional: defaults to GOOGLE_API_KEY
HF_TOKEN=xxx # Optional: for huggingface judge / dataset extraction

# Vertex AI Configuration (Optional)
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

SKIP_LLM=false #optional: skip LLM calls for faster development
NAAMSE_RANDOM_SEED=1234 #optional: for reproducibility during development
LOG_LEVEL=INFO #optional: controls logging verbosity

# Optional: Configuration for LLM models
GEMINI_MODEL=gemini-2.5-flash # Global fallback model
MUTATION_ENGINE_MODEL=gemini-2.5-flash # Overrides model for the mutation engine
BEHAVIORAL_ENGINE_MODEL=gemini-2.5-flash # Overrides model for the behavioral engine
